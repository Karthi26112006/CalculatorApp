<CalcButton@Button>:
    font_size: 32
    background_color: (0.15, 0.15, 0.15, 1)

<CalcLayout>:
    orientation: 'vertical'
    display: entry
    
    TextInput:
        id: entry
        font_size: 64
        multiline: False
        readonly: True
        halign: 'right'
        size_hint: (1, 0.25)
        background_color: (0, 0, 0, 1)
        foreground_color: (1, 1, 1, 1)

    GridLayout:
        cols: 4
        spacing: 2
        padding: 2

        # Row 1
        CalcButton:
            text: "7"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "8"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "9"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "/"
            background_color: (1, 0.5, 0, 1)
            on_press: root.append_text(self.text)

        # Row 2
        CalcButton:
            text: "4"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "5"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "6"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "*"
            background_color: (1, 0.5, 0, 1)
            on_press: root.append_text(self.text)

        # Row 3
        CalcButton:
            text: "1"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "2"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "3"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "-"
            background_color: (1, 0.5, 0, 1)
            on_press: root.append_text(self.text)

        # Row 4
        CalcButton:
            text: "AC"
            background_color: (0.7, 0.2, 0.2, 1)
            on_press: entry.text = ""
        CalcButton:
            text: "0"
            on_press: root.append_text(self.text)
        CalcButton:
            text: "="
            background_color: (0, 0.6, 0.3, 1)
            on_press: root.calculate(entry.text)
        CalcButton:
            text: "+"
            background_color: (1, 0.5, 0, 1)
            on_press: root.append_text(self.text)